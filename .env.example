# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=CHANGE_ME_minimum_32_chars_random_string

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexvault
POSTGRES_USER=nexvault
POSTGRES_PASSWORD=CHANGE_ME_strong_password
DATABASE_URL=postgresql+asyncpg://nexvault:CHANGE_ME_strong_password@localhost:5432/nexvault

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@localhost:6379/0

# ── Vault / Encryption ────────────────────────────────────────────────────────
# AES-256 key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
VAULT_ENCRYPTION_KEY=CHANGE_ME_64_hex_chars_aes256_key

# ── Semantic Cache ────────────────────────────────────────────────────────────
CACHE_EMBEDDING_MODEL=all-MiniLM-L6-v2
CACHE_SIMILARITY_THRESHOLD=0.95
CACHE_TTL_SECONDS=3600

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
